<Window x:Class="HabboCustomLauncher.LoadingWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabboCustomLauncher"
        x:Name="Window"
        mc:Ignorable="d" Width="602" Height="212" CanResize="False" SystemDecorations="BorderOnly" Opacity="1"
        Title="HabboCustomLauncher"
        WindowStartupLocation="CenterScreen" Background="Black" FontFamily="{StaticResource NewSegoeUI}" Icon="/Assets/HabboCustomLauncherIcon.ico">
	<Grid>
		<Canvas ClipToBounds="true">
			<Image Source="/Assets/modal-backdrop-pink.png" Canvas.Left="-300" Canvas.Top="-100" Stretch="Uniform"/>
		</Canvas>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="32"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<Label Name="TitleBarLabel" Grid.Row="0" Background="#A22A60" Foreground="White" Content="    HabboCustomLauncher" VerticalContentAlignment="Center"/>
			<local:CustomButton x:Name="CloseButton" IsFocusable="False" Grid.Row="0" Foreground="White" HorizontalAlignment="Right" Text="   X   " BackColor="#78FF0000"/>
			<Border Grid.Row="1" BorderThickness="1,0,1,1" BorderBrush="#A22A60">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="1"/>
						<RowDefinition Height="60"/>
					</Grid.RowDefinitions>
					<TextBlock x:Name="StatusLabel" Grid.Row="0" Margin="15" Text="Unknown status!" TextTrimming="CharacterEllipsis" Foreground="White" FontSize="30" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
					<Grid Grid.Row="1" Background="#A22A60" Opacity="0.2" Margin="10,0,10,0"/>
					<local:CustomButton x:Name="MainMenuButton" Grid.Row="2" Text="Return to main menu" Margin="10"/>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>